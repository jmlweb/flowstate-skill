{
  "name": "@flowstate/cli",
  "version": "1.2.1",
  "description": "Deterministic CLI for flowstate backlog management",
  "type": "module",
  "bin": {
    "flowstate": "./dist/bin/flowstate.js"
  },
  "scripts": {
